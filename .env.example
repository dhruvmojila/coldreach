# ColdReach Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Then edit .env with your values. Never commit .env to git.
#
# All variables are optional — defaults work out of the box with SQLite
# and no Docker. Start with `coldreach verify test@email.com` right away.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (zero setup, local file)
# Production: switch to PostgreSQL after running `docker compose up postgres`
COLDREACH_DATABASE_URL=sqlite+aiosqlite:///./coldreach.db
# COLDREACH_DATABASE_URL=postgresql+asyncpg://coldreach:coldreach_dev@localhost:5433/coldreach


# ── Cache (Redis) ─────────────────────────────────────────────────────────────
# Requires: docker compose up redis
# Without Redis: results are cached in SQLite only (still works).
COLDREACH_REDIS_URL=redis://localhost:6380/0
COLDREACH_CACHE_TTL_DAYS=7


# ── Docker Service URLs ───────────────────────────────────────────────────────
# Start all: docker compose up -d
# Ports are offset from defaults to avoid clashing with local dev services:
#   postgres :5433  redis :6380  searxng :8088  reacher :8083
COLDREACH_SEARXNG_URL=http://localhost:8088
COLDREACH_REACHER_URL=http://localhost:8083
COLDREACH_SPIDERFOOT_CONTAINER=coldreach-spiderfoot
COLDREACH_THEHARVESTER_CONTAINER=coldreach-theharvester


# ── LLM — Groq API (Optional) ────────────────────────────────────────────────
# This is the ONLY paid/external key in ColdReach.
# Free tier: 14,400 tokens/minute on llama-3.1-70b-versatile
# Get your key: https://console.groq.com/  (free, no credit card required)
#
# Unlocks:
#   - Personalized cold email drafting
#   - Subject line variants (A/B suggestions)
#   - Company summary from crawled content
#
# Leave commented out to use ColdReach without any API keys.
# COLDREACH_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Verification Behaviour ────────────────────────────────────────────────────
COLDREACH_SMTP_TIMEOUT=10
COLDREACH_DNS_TIMEOUT=5.0
COLDREACH_MAX_CONCURRENT_SOURCES=5
COLDREACH_REQUEST_DELAY_SECONDS=1.0


# ── Scoring ───────────────────────────────────────────────────────────────────
# Emails below this confidence are hidden from default output (shown with --all)
COLDREACH_MIN_CONFIDENCE_TO_DISPLAY=20
